# === Seleção do Provider LLM ===
# Qual provider usar. Valores válidos: openai, gemini, anthropic
# Padrão: openai (se não definido)
LLM_PROVIDER=openai

# === Override de modelo (opcional) ===
# Sobrescreve o modelo padrão do provider selecionado.
# Se não definido, cada provider usa seu próprio padrão:
#   openai    → gpt-3.5-turbo
#   gemini    → gemini-1.5-flash
#   anthropic → claude-haiku-4-5-20251001
LLM_MODEL=

# === Chaves de API dos providers ===
# Apenas a chave do provider selecionado é necessária em runtime.
OPENAI_API_KEY=sua_chave_openai_aqui
GEMINI_API_KEY=sua_chave_gemini_aqui
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
